# Port to listen on (default: 3000)
PORT=3000

# Auth token — leave blank to auto-generate on first run
AUTH_TOKEN=

# Cloudflared tunnel — ON by default so the QR always shows a public HTTPS URL.
# Set to false only if you have a stable public URL and want to set PUBLIC_URL instead.
# USE_CLOUDFLARED=false

# Optional: fixed public URL (e.g. a subdomain via your own Cloudflare tunnel).
# If set, skips the auto-tunnel and uses this URL in the QR instead.
# PUBLIC_URL=https://terminal.example.com

# Optional: path to an SSH private key on this machine.
# If set, the R1 can connect without entering a password.
# SSH_KEY_PATH=/home/user/.ssh/id_ed25519
