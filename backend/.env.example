# Port to listen on (default: 3000)
PORT=3000

# Auth token — leave blank to auto-generate on first run
AUTH_TOKEN=

# ── Web access (pick one) ─────────────────────────────────────────
# Option A: set a fixed public URL (subdomain, public IP, etc.)
# PUBLIC_URL=https://terminal.frontierfield.xyz

# Option B: auto-spawn a cloudflared quick tunnel on startup
# USE_CLOUDFLARED=true

# ── Pre-configured SSH target ─────────────────────────────────────
# When set, the R1 skips the connect screen and goes straight to the terminal.
# Leave blank to let the user enter a host on the R1 each time.
# SSH_HOST=127.0.0.1
# SSH_PORT=22
# SSH_USER=root

# ── SSH key auth ──────────────────────────────────────────────────
# Path to a private key on this server. If set, no password is needed from the R1.
# SSH_KEY_PATH=/root/.ssh/id_ed25519
